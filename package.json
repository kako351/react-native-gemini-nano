{
  "name": "react-native-gemini-nano",
  "version": "0.1.0",
  "description": "React Native TurboModule bridge for Android AICore / Gemini Nano.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "scripts": {
    "example:install": "cd example && npm install",
    "example:start": "cd example && npm start",
    "example:android": "cd example && npm run android",
    "example:lint": "cd example && npm run lint"
  },
  "files": [
    "src",
    "android",
    "example",
    "react-native.config.js",
    "tsconfig.json"
  ],
  "keywords": [
    "react-native",
    "android",
    "turbo-module",
    "gemini-nano",
    "aicore"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=19.2.3",
    "react-native": ">=0.84.0"
  },
  "devDependencies": {
    "@react-native/codegen": "^0.84.0",
    "@types/react": "^19.1.1",
    "react": "^19.2.3",
    "react-native": "^0.84.0",
    "typescript": "^5.8.3"
  },
  "codegenConfig": {
    "name": "NativeGeminiNanoSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.gemininano"
    }
  }
}
